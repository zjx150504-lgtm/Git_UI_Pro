{
  "name": "git-ui-pro",
  "version": "0.1.9",
  "private": true,
  "description": "中文桌面 Git 可视化管理软件",
  "author": {
    "name": "Git UI Pro",
    "email": "zjx150504-lgtm@users.noreply.github.com",
    "url": "https://github.com/zjx150504-lgtm"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "electron",
    "react",
    "desktop",
    "git-client",
    "git-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zjx150504-lgtm/Git_UI_Pro.git"
  },
  "bugs": {
    "url": "https://github.com/zjx150504-lgtm/Git_UI_Pro/issues"
  },
  "homepage": "https://github.com/zjx150504-lgtm/Git_UI_Pro#readme",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-ts,electron -c cyan,magenta,green \"vite --host 127.0.0.1\" \"tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on dist-electron/main.js http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "test:merge": "npm run build:electron && node scripts/test-merge-service.mjs",
    "test:release": "node --test scripts/test-release-console.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "release:win": "node scripts/release-console.mjs",
    "dist": "npm run icons && npm run build && electron-builder",
    "dist:dir": "npm run icons && npm run build && electron-builder --dir",
    "dist:win": "npm run icons && npm run build && electron-builder --win",
    "dist:linux": "npm run icons && npm run build && electron-builder --linux",
    "dist:mac": "npm run icons && npm run build && electron-builder --mac",
    "dist:win:signed": "npm run icons && npm run build && electron-builder --win -c.win.signExecutable=true",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "postinstall": "node scripts/install-node-pty-prebuild.mjs"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "29.4.6",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gitui.pro",
    "productName": "Git UI Pro",
    "copyright": "Copyright © 2026 Git UI Pro",
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "electronVersion": "29.4.6",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/package.json",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/lib/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/build/Release/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/prebuilds/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/third_party/**/*"
    ],
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/build/Release/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/prebuilds/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/third_party/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true,
      "signExecutable": false,
      "signtoolOptions": {
        "publisherName": "Git UI Pro",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Git UI Pro",
      "artifactName": "Git-UI-Pro-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Git-UI-Pro-Portable-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "artifactName": "Git-UI-Pro-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons",
      "category": "Development",
      "maintainer": "Git UI Pro <zjx150504-lgtm@users.noreply.github.com>",
      "artifactName": "Git-UI-Pro-${version}-${os}-${arch}.${ext}"
    }
  }
}
